//0122229
fn main() {
    let var1: i32 = 0;
    if var1 == 0 {
        print("0");
    }

    let mut var2: bool = true;
    while var2 {
        print("1");
        break;
    }

    let mut var3: usize = 0;
    loop {
        print("2");
        if var3 > 2 {
            break;
        }
        var3 = var3 + 1;
    }

    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    while i < 5 {
        sum = sum + i;
        i = i + 1;
    }
    if sum == 10 {
        print("9");
    }
}
