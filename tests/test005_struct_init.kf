//30201520
struct Point { x: i32, y: i32 }
struct Stats { count: i32, total: i32 }
fn main() {
    let p = Point { x: 10, y: 20 };
    let sum = p.x + p.y;
    print("{}", sum);

    let p2 = Point { x: 30, y: 50 };
    let dx = p2.x - p.x;
    print("{}", dx);

    let q = Point { x: 3, y: 5 };
    let product = q.x * q.y;
    print("{}", product);

    let s = Stats { count: 5, total: 100 };
    let avg = s.total / s.count;
    print("{}", avg);
}
