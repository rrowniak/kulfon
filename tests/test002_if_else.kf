//01203
fn main() {
    let flag: bool = true;
    if flag {
        print("0");
    }

    if false {
        print("!");
    } else {
        print("1");
    }

    let x: i32 = 5;
    if x > 10 {
        print("!");
    } else if x > 3 {
        print("2");
    } else {
        print("!");
    }

    let y: i32 = 1;
    if y == 1 {
        print("0");
    }

    if false {
        print("!");
    } else {
        print("3");
    }
}
